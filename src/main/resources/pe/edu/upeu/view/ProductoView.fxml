<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pe.edu.upeu.controller.ProductoController">

    <!-- ================= FORMULARIO ================= -->
    <top>
        <GridPane hgap="10" vgap="10" style="-fx-padding:15;">

            <Label text="Nombre"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtNombre"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Descripción"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtDescripcion"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Precio"
                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtPrecio"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Stock"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="txtStock"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <!-- Imagen: muestra la foto seleccionada (150x150 px) -->
            <Label text="Foto"
                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <ImageView fx:id="imgProducto"
                       fitWidth="150" fitHeight="150"
                       preserveRatio="true"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <!-- Botón que abre el explorador de archivos -->
            <Button text="Seleccionar Foto"
                    onAction="#seleccionarFoto"
                    GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <!-- Botones CRUD -->
            <HBox spacing="10"
                  GridPane.rowIndex="6"
                  GridPane.columnIndex="1">
                <Button fx:id="btnGuardar"   text="Guardar"    onAction="#guardar"/>
                <Button fx:id="btnActualizar" text="Actualizar" onAction="#actualizar"/>
                <Button fx:id="btnEliminar"  text="Eliminar"   onAction="#eliminar"/>
            </HBox>

        </GridPane>
    </top>

    <!-- ================= TABLA ================= -->
    <center>
        <TableView fx:id="tablaProductos">
            <columns>
                <TableColumn fx:id="colId"          text="ID"/>
                <TableColumn fx:id="colNombre"      text="Nombre"/>
                <TableColumn fx:id="colDescripcion" text="Descripción"/>
                <TableColumn fx:id="colPrecio"      text="Precio"/>
                <TableColumn fx:id="colStock"       text="Stock"/>
            </columns>
        </TableView>
    </center>

</BorderPane>