<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- StackPane como raíz: aquí va el fx:controller -->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="pe.edu.upeu.controller.LoginController"
           style="-fx-background-color:#2c3e50;">

    <!-- Caja blanca centrada con sombra -->
    <VBox styleClass="login-box"
          spacing="12"
          alignment="CENTER"
          maxWidth="280">

        <!-- Título -->
        <Label text="CompraVende" styleClass="label-titulo"/>
        <Label text="Ingresa tus credenciales"
               style="-fx-text-fill:#7f8c8d; -fx-font-size:12px;"/>

        <!-- Campo usuario -->
        <TextField fx:id="txtUser" promptText="Usuario"/>

        <!-- Campo contraseña -->
        <PasswordField fx:id="txtPass" promptText="Contraseña"/>

        <!-- Botón ingresar -->
        <Button text="Ingresar" maxWidth="Infinity" onAction="#login"/>

        <!-- Mensaje de error en rojo -->
        <Label fx:id="lblMensaje" style="-fx-text-fill:#e74c3c;"/>

    </VBox>

</StackPane>