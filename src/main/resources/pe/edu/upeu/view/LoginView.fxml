<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Vista de Login -->
<VBox spacing="10"
      alignment="CENTER"
      style="-fx-padding:30;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="pe.edu.upeu.controller.LoginController">

    <!-- Usuario -->
    <TextField fx:id="txtUser"
               promptText="Usuario"/>

    <!-- Contraseña -->
    <PasswordField fx:id="txtPass"
                   promptText="Contraseña"/>

    <!-- Botón login -->
    <Button text="Ingresar"
            onAction="#login"/>

    <!-- Mensaje -->
    <Label fx:id="lblMensaje"/>

</VBox>