<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="ticket"
              pageWidth="226" pageHeight="400"
              columnWidth="206"
              leftMargin="10" rightMargin="10"
              topMargin="10" bottomMargin="10">

    <!-- Parámetros que se pasan desde Java al generar el PDF -->
    <parameter name="numero"       class="java.lang.Integer"/>
    <parameter name="producto"     class="java.lang.String"/>
    <parameter name="precio"       class="java.lang.Double"/>
    <parameter name="comprador"    class="java.lang.String"/>
    <parameter name="fecha"        class="java.lang.String"/>

    <!-- Sin datasource: el ticket usa solo parámetros -->
    <queryString><![CDATA[]]></queryString>

    <!-- ===== ENCABEZADO ===== -->
    <title>
        <band height="60">
            <!-- Nombre de la tienda -->
            <staticText>
                <reportElement x="0" y="0" width="206" height="20"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[CompraVende]]></text>
            </staticText>
            <!-- Subtítulo -->
            <staticText>
                <reportElement x="0" y="20" width="206" height="15"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Comprobante de Compra]]></text>
            </staticText>
            <!-- Línea separadora -->
            <line>
                <reportElement x="0" y="40" width="206" height="1"/>
            </line>
            <!-- Número de transacción -->
            <textField>
                <reportElement x="0" y="45" width="206" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA["N° Transacción: " + $P{numero}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ===== DETALLE DEL TICKET ===== -->
    <detail>
        <band height="120">

            <!-- Producto -->
            <staticText>
                <reportElement x="0" y="5" width="80" height="15"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Producto:]]></text>
            </staticText>
            <textField>
                <reportElement x="85" y="5" width="121" height="15"/>
                <textFieldExpression><![CDATA[$P{producto}]]></textFieldExpression>
            </textField>

            <!-- Precio -->
            <staticText>
                <reportElement x="0" y="25" width="80" height="15"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Precio:]]></text>
            </staticText>
            <textField>
                <reportElement x="85" y="25" width="121" height="15"/>
                <textFieldExpression><![CDATA["S/ " + String.format("%.2f", $P{precio})]]></textFieldExpression>
            </textField>

            <!-- Comprador -->
            <staticText>
                <reportElement x="0" y="45" width="80" height="15"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Comprador:]]></text>
            </staticText>
            <textField>
                <reportElement x="85" y="45" width="121" height="15"/>
                <textFieldExpression><![CDATA[$P{comprador}]]></textFieldExpression>
            </textField>

            <!-- Fecha -->
            <staticText>
                <reportElement x="0" y="65" width="80" height="15"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Fecha:]]></text>
            </staticText>
            <textField>
                <reportElement x="85" y="65" width="121" height="15"/>
                <textFieldExpression><![CDATA[$P{fecha}]]></textFieldExpression>
            </textField>

            <!-- Línea separadora al pie -->
            <line>
                <reportElement x="0" y="90" width="206" height="1"/>
            </line>

            <!-- Mensaje de cierre -->
            <staticText>
                <reportElement x="0" y="95" width="206" height="15"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[¡Gracias por tu compra!]]></text>
            </staticText>

        </band>
    </detail>

</jasperReport>